generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   BigInt   @unique
  username     String?
  firstName    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  character    Character?
}

model Character {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  user                User     @relation(fields: [userId], references: [id])
  level               Int      @default(1)
  energy              Int      @default(100)
  lastEnergyUpdate    DateTime @default(now())
  endurance           Int      @default(10)
  strength            Int      @default(10)
  strengthAtLevelUp   Int      @default(0)
  agility             Int      @default(10)
  enduranceAtLevelUp  Int      @default(10)
  luck                Int      @default(0)
  strengthProgress    Float    @default(0)   // accumulated normalized attack damage toward next Strength point
  enduranceProgress   Float    @default(0)   // accumulated normalized damage taken toward next Endurance point
  agilityProgress     Float    @default(0)   // accumulated normalized skill damage + healed amount toward next Agility point
  gold                Int      @default(0)
  trophies            Int      @default(0)
  crystals            Int      @default(0)
  potionCharges       Int      @default(3)
  equippedSkills      String[] @default([])
  currentRun          Json?    // активный забег: { rooms, index }; null = забега нет
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  inventoryItems      InventoryItem[]
}

model Item {
  id            String   @id @default(cuid())
  slot          String   // "weapon" | "armor" | "helmet" | "boots" | "gloves" | "amulet"
  tier          Int      // 1-10 for weapon/armor, 1-5 for helmet/boots/gloves/amulet
  nameRu        String   // Russian display name, e.g. "Стальной длинный меч"
  iconPath      String   // e.g. "weapons/weapon_07.png"
  levelRequired Int      // minimum character level to equip
  damage        Int?     // weapon only
  armor         Int?     // armor/helmet/gloves only
  moveSpeed     Float?   // boots only
  luck          Int?     // amulet only
  inventoryItems InventoryItem[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  characterId Int
  character   Character @relation(fields: [characterId], references: [id])
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  equipped    Boolean   @default(false)
  acquiredAt  DateTime  @default(now())

  @@index([characterId])
}